{
  "name": "basic-workflow-completion",
  "description": "Hooks fire events when .active-workflow exists",
  "setup": {
    "active_workflow": {
      "workflow_id": "TEST-001",
      "skill": "brainstorming",
      "topic": "test-feature",
      "step": "explore_context",
      "step_number": 1,
      "started": "2026-03-21T10:00:00Z",
      "repo": "test-repo",
      "task_type": "feature",
      "sp_version": "1.3.0"
    },
    "workflow_events": []
  },
  "hooks_to_test": [
    {
      "hook": "user-prompt-submit",
      "input": {"prompt": "yes looks good"},
      "expect_event": "user_message"
    },
    {
      "hook": "task-completed",
      "input": {"task_id": "1", "task_subject": "Test task", "task_description": "A test"},
      "expect_event": "task_completed"
    },
    {
      "hook": "stop",
      "input": {"last_assistant_message": "Done with the implementation"},
      "expect_event": "turn_completed"
    }
  ],
  "expected": {
    "event_types_present": ["user_message", "task_completed", "turn_completed"],
    "workflow_id_correct": "TEST-001"
  }
}
