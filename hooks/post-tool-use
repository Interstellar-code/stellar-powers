#!/usr/bin/env bash
# PostToolUse hook for stellar-powers plugin
# Logs Agent dispatches and checks persona template compliance.
# Receives JSON on stdin from Claude Code.
# MUST exit 0 in all cases (silent degradation).

# Ensure any unexpected error exits cleanly
trap 'exit 0' ERR

# Capture stdin before it's consumed, pass via env var to python3
_SP_HOOK_INPUT=$(cat 2>/dev/null) || exit 0
export _SP_HOOK_INPUT

# All logic in a single python3 call. Input passed via env var to avoid
# ARG_MAX limits on large prompts and stdin/heredoc conflicts.
python3 -c '
import json, sys, os
from datetime import datetime, timezone

try:
    data = json.loads(os.environ.get("_SP_HOOK_INPUT", ""))
except Exception:
    sys.exit(0)

tool_name = data.get("tool_name", "")
if tool_name != "Agent":
    sys.exit(0)

cwd = data.get("cwd", "")
if not cwd:
    sys.exit(0)

# Check feedback enabled
config_path = os.path.join(cwd, ".stellar-powers", "config.json")
if os.path.exists(config_path):
    try:
        if not json.load(open(config_path)).get("feedback_enabled", True):
            sys.exit(0)
    except:
        pass

session_id = data.get("session_id", "")
tool_input = data.get("tool_input", {})
prompt = tool_input.get("prompt", "")
subagent_type = tool_input.get("subagent_type", "")
model = tool_input.get("model", "")
description = tool_input.get("description", "")

# Platform-internal subagent types — skip entirely (not user-visible work)
if subagent_type in ("Plan", "claude-code-guide", "statusline-setup"):
    sys.exit(0)

# Stellar-powers internal agent types — skip entirely
if subagent_type and subagent_type.startswith("stellar-powers:"):
    sys.exit(0)

# Exempt from persona violation checks but still log the dispatch
exempt_from_persona_check = (
    subagent_type == "Explore"
    or "spec document reviewer" in prompt
    or "code quality reviewer" in prompt
    or "plan document reviewer" in prompt
)

# Read workflow_id from .active-workflow
aw_path = os.path.join(cwd, ".stellar-powers", ".active-workflow")
workflow_id = ""
if os.path.exists(aw_path):
    try:
        workflow_id = json.load(open(aw_path)).get("workflow_id", "")
    except Exception:
        pass

# Ensure .stellar-powers directory exists
sp_dir = os.path.join(cwd, ".stellar-powers")
try:
    os.makedirs(sp_dir, exist_ok=True)
except Exception:
    sys.exit(0)

workflow_file = os.path.join(sp_dir, "workflow.jsonl")
timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

# Detect persona template markers (case-insensitive)
prompt_lower = prompt.lower()
markers = [
    "you are a",
    "agent persona:",
    "## agent persona catalog",
    "## persona summary",
    "### core:",
]
has_persona = any(m in prompt_lower for m in markers)

# Write agent_dispatch event
dispatch_event = {
    "ts": timestamp,
    "event": "agent_dispatch",
    "workflow_id": workflow_id,
    "session": session_id,
    "data": {
        "persona": "",
        "task": description,
        "model": model,
        "has_persona_template": has_persona,
    },
}

try:
    with open(workflow_file, "a") as f:
        f.write(json.dumps(dispatch_event, ensure_ascii=False) + "\n")
except Exception:
    sys.exit(0)

# If no persona detected and not exempt, log violation
if not has_persona and not exempt_from_persona_check:
    violation_event = {
        "ts": timestamp,
        "event": "hook_violation",
        "workflow_id": workflow_id,
        "session": session_id,
        "data": {
            "type": "missing_persona_template",
            "tool_input_summary": prompt[:100],
            "reason": "Agent dispatch missing persona template markers",
        },
    }

    try:
        with open(workflow_file, "a") as f:
            f.write(json.dumps(violation_event, ensure_ascii=False) + "\n")
    except Exception:
        pass

    # Log to workflow file only — stderr output from async hooks surfaces
    # as "PostToolUse:Agent hook error" in Claude Code, which is confusing.
    # The violation is already recorded in workflow.jsonl above.

sys.exit(0)
'

exit 0
